# Maintainer: Charles Mills <charles@charlesmills.dev>

pkgname=gmpublished-bin
_pkgname=gmpublished
_github_repo='charles-mills/gmpublished'
pkgver=1.0.0
_release_tag='1.0.0'
pkgrel=1
pkgdesc="Native Workshop Publishing Utility for Garry's Mod"
arch=('x86_64')
url="https://github.com/${_github_repo}"
license=('GPL-3.0-only')
depends=(
  'desktop-file-utils'
  'fontconfig'
  'gtk-update-icon-cache'
  'hicolor-icon-theme'
  'libx11'
  'libxcb'
  'libxkbcommon'
  'shared-mime-info'
  'vulkan-driver'
  'vulkan-icd-loader'
  'wayland'
)
provides=("${_pkgname}=${pkgver}")
conflicts=("${_pkgname}")
source=(
  "${_pkgname}-${pkgver}-x86_64-linux.zip::\
${url}/releases/download/${_release_tag}/${_pkgname}-${pkgver}-x86_64-linux.zip"
  "${pkgname}-${pkgver}-LICENSE::\
https://raw.githubusercontent.com/${_github_repo}/${_release_tag}/LICENSE"
  "${pkgname}-${pkgver}.png::\
https://raw.githubusercontent.com/${_github_repo}/${_release_tag}/packaging/icons/128x128.png"
)
sha256sums=('SKIP'
            'SKIP'
            'SKIP')

package() {
  install -Dm755 "${srcdir}/${_pkgname}" \
    "${pkgdir}/usr/lib/${_pkgname}/${_pkgname}"
  install -Dm644 "${srcdir}/libsteam_api.so" \
    "${pkgdir}/usr/lib/${_pkgname}/libsteam_api.so"

  install -d "${pkgdir}/usr/bin"
  ln -s "../lib/${_pkgname}/${_pkgname}" "${pkgdir}/usr/bin/${_pkgname}"

  install -Dm644 "${srcdir}/${pkgname}-${pkgver}-LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "${srcdir}/${pkgname}-${pkgver}.png" \
    "${pkgdir}/usr/share/icons/hicolor/128x128/apps/${_pkgname}.png"

  cat > "${srcdir}/${_pkgname}.desktop" <<EOF
[Desktop Entry]
Name=gmpublished
Comment=${pkgdesc}
Exec=${_pkgname} -e %f
Icon=${_pkgname}
Terminal=false
Type=Application
Categories=Utility;Game;Development;
MimeType=application/gma;
EOF
  install -Dm644 "${srcdir}/${_pkgname}.desktop" \
    "${pkgdir}/usr/share/applications/${_pkgname}.desktop"

  cat > "${srcdir}/application-gma.xml" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/gma">
    <comment>Garry's Mod Addon</comment>
    <glob pattern="*.gma"/>
  </mime-type>
</mime-info>
EOF
  install -Dm644 "${srcdir}/application-gma.xml" \
    "${pkgdir}/usr/share/mime/packages/application-gma.xml"
}
